# Supabase (opcional — sin esto, src/lib/supabase.ts usa el proyecto de
# desarrollo hardcodeado; en producción real deberían configurarse).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile (captcha de registro/login). Crea un sitio en
# https://dash.cloudflare.com/?to=/:account/turnstile — sin estas dos
# variables, el captcha simplemente no se muestra y el registro/login
# funcionan igual que hoy.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
